APP_NAME=ExpenseHub
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=expense_manager
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_RECEIPTS_ROOT=expensehub

RECEIPTS_SIGNED_URL_TTL=15
RECEIPTS_MAX_FILE_SIZE_KB=5120

VITE_APP_NAME="${APP_NAME}"

# ── Shared hosting (cPanel) ─────────────────────────────────────────────
# Document root → public/   |   Run: php artisan storage:link
# After deploy: php artisan migrate --force && php artisan config:cache
# Cron (every minute): * * * * * cd /path/to/app && php artisan schedule:run
# Verify: php artisan app:install-check
# Use QUEUE_CONNECTION=sync (no background worker needed)

# Google OAuth (Sign in with Google)
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID → Web application
# 3. Authorized JavaScript origins: your APP_URL (e.g. http://localhost or http://localhost:8000)
# 4. Authorized redirect URI: ${APP_URL}/auth/google/callback
#    XAMPP example: http://localhost/expense-manager/public/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# Super admin / support contact shown to users
SUPPORT_EMAIL=support@expensehub.in
SUPPORT_PHONE="+91 98765 43210"

EXPENSE_AUTO_APPROVE_LIMIT=500
EXPENSE_RECEIPT_REQUIRED_ABOVE=10000
PETTY_CASH_LIMIT=5000

# Marketing / SEO (optional overrides)
# MARKETING_SEO_TITLE=
# MARKETING_SEO_DESCRIPTION=
# MARKETING_SEO_KEYWORDS=
# MARKETING_OG_IMAGE=/images/og-expensehub.png
# MARKETING_TWITTER_HANDLE=@expensehub
